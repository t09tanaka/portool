# Committed test environment. One file serves both worlds:
#  - `portool exec -e .env.test -- <cmd>`: TEST_DB_PORT is this worktree's
#    allocation, and the reference below expands to it.
#  - plain dotenv loader (CI, no portool): the :-5433 default applies and
#    matches compose's test-db fallback port.
DATABASE_URL=postgresql://postgres:password@127.0.0.1:${TEST_DB_PORT:-5433}/app_test
